# ── Generated data ────────────────────────────────────────────────────────────
# Raw downloads are large; do not commit them
data/raw_downloads/

# CCA pipeline outputs (regenerated by run_cca_pipeline.sh)
data/cca/

# scVI pipeline outputs (regenerated by run_scvi_pipeline.sh)
data/scvi/

# LOO benchmark per-fold prediction files (regenerated by run_loo_benchmark.sh)
data/loo/

# GSE176031 PDAC raw DGE files (GEO open access; large, regeneratable)
data/gse176031_dge/

# Generated figures (regenerated by pipeline / exploration notebooks)
data/clonotype_landscape.png

# Shared processed files
data/caushi2021_ranked_clonotypes.csv
data/caushi2021_cd8_annotated.rds
data/memory_monitor.log

# ── Trained models ────────────────────────────────────────────────────────────
# Main reference model
models/scanvi_reference/
# Per-patient LOO models (~100–120 MB each; regenerated by run_loo_benchmark.sh)
models/scanvi_reference_su*/

# ── Executed notebooks (timestamped copies with cell outputs) ─────────────────
notebooks/executed/
# benchmarking: both naming conventions (executed_* prefix and *_executed suffix)
benchmarking/executed_*.ipynb
benchmarking/*_executed.ipynb

